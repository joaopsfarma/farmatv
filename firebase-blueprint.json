{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "Uma mensagem enviada pelo intercomunicador.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "O conteúdo da mensagem."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora em que a mensagem foi enviada."
        },
        "active": {
          "type": "boolean",
          "description": "Se a mensagem deve ser exibida na TV."
        },
        "resolvedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora em que a mensagem foi resolvida/limpa."
        },
        "senderName": {
          "type": "string",
          "description": "Nome de quem enviou (opcional)."
        },
        "senderId": {
          "type": "string",
          "description": "ID do usuário que enviou a mensagem."
        },
        "station": {
          "type": "string",
          "enum": ["Farmácia UTI", "Farmácia PS", "Farmácia CC", "Farmácia Central"],
          "description": "Estação de origem da mensagem."
        },
        "destination": {
          "type": "string",
          "enum": ["CENTRAL", "CAF"],
          "description": "Estação de destino da mensagem."
        }
      },
      "required": ["text", "createdAt", "active", "station", "senderId"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Coleção de mensagens para exibição em tempo real."
    }
  }
}
