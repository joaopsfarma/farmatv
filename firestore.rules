rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Validation for Message
    function isValidMessage(data) {
      return data.keys().hasAll(['text', 'createdAt', 'active', 'station', 'senderId']) 
        && data.keys().size() <= 14 // Adjusted for station and other fields
        && data.text is string && data.text.size() <= 1000
        && data.createdAt == request.time
        && data.active is bool
        && data.station in ['Farmácia UTI', 'Farmácia PS', 'Farmácia CC', 'Farmácia Central']
        && (!data.keys().hasAny(['destination']) || data.destination in ['CENTRAL', 'CAF'])
        && data.senderId == request.auth.uid;
    }

    match /messages/{messageId} {
      allow list: if isSignedIn() && (
        (resource.data.active == true) || 
        (request.auth.token.email == 'joaopsfarma@gmail.com' && request.auth.token.email_verified == true)
      );
      allow get: if isSignedIn();
      
      // Anyone signed in can send a message
      allow create: if isSignedIn() 
        && isValidId(messageId)
        && isValidMessage(incoming());

      // Only the sender and admin can deactivate messages
      allow update: if isSignedIn()
        && (resource.data.senderId == request.auth.uid || (request.auth.token.email == 'joaopsfarma@gmail.com' && request.auth.token.email_verified == true))
        && (
          (incoming().diff(resource.data).affectedKeys().hasOnly(['active', 'resolvedAt']) && incoming().resolvedAt == request.time)
          || (incoming().diff(resource.data).affectedKeys().hasOnly(['active']))
        );
        
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }
  }
}
